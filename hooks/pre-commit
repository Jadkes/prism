#!/bin/bash
# pre-commit - Git pre-commit hook for prism
#
# Purpose: Runs prism on all staged .c/.cpp files
#          and blocks the commit if errors are found.
#
# Design: Uses git diff --cached to find staged files,
#         then runs prism on each. If any file has
#         errors, the commit is blocked (exit 1).

# Get staged .c and .cpp files
files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|cpp|cxx|cc)$')

if [ -z "$files" ]; then
    exit 0
fi

echo "Running prism on staged files..."
echo ""

for f in $files; do
    echo "Checking: $f"
    output=$(./prism "$f" 2>&1)
    result=$?

    if [ $result -ne 0 ]; then
        echo "prism found errors in $f"
        echo "$output"
        echo ""
        echo "Commit blocked. Fix errors before committing."
        exit 1
    else
        echo "  OK"
    fi
    echo ""
done

exit 0
